# Notification service
NOTIFICATION_SERVICE_PORT=4010
NODE_ENV=production

# Must match the RabbitMQ instance on Docker network `chatapp-network`
# (default from chatapp-conversation compose)
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672

# Optional: future push → chat-service delivery-ack (not used while consumer is log-only)
CHAT_SERVICE_URL=http://chat-service:4000
INTERNAL_API_TOKEN=supersecret_internal_token_12345

